#!/usr/bin/env bash
set -euo pipefail
HERE="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
. "$HERE/review-watcher-lib.sh"
rw_load_config

owner="$1"; repo="$2"; pr="$3"
max_attempts=20
attempt=1

while [ "$attempt" -le "$max_attempts" ]; do
  v="$(rw_merge_ready "$owner" "$repo" "$pr")"
  case "$v" in
    READY)
      gh pr merge "$pr" --repo "$owner/$repo" --squash
      exit 0 ;;
    PENDING)
      sleep 30 ;;
    NOT_READY)
      echo "rw-merge: $owner/$repo#$pr is not ready to merge (not approved+mergeable, or CI is red); refusing to merge" >&2
      exit 1 ;;
  esac
  attempt=$((attempt+1))
done

echo "rw-merge: $owner/$repo#$pr — CI still pending after $max_attempts attempts" >&2
exit 1

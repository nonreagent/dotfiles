# Selection layer: which upstream paths the @nonreagent agent gets. One path per
# line; '#' starts a comment. Each entry is a path as it appears in
# nonrational/dotfiles — upstream keeps its dotfiles under home/, so entries carry
# that prefix and match its `manifest` (the placement layer) 1:1. build.sh reads
# the target + condition from there. Identity-bearing / transformed files
# (.gitconfig, .claude/CLAUDE.md) are NOT here; build.sh's transformation layer
# writes them.

# bin (resolves to the upstream `home/bin.Linux ~/bin os=Linux` row -> home/bin)
home/bin.Linux

# shell
home/.bashrc
home/.bashrc.Linux
home/.bash_profile
home/.bash_completion
home/.bash_completion.d
home/.inputrc

# git (identity-bearing .gitconfig is special-cased; these are safe verbatim)
home/.githelpers
home/.gitignore_global

# tmux / editor / repl
home/.tmux.conf
home/.vimrc
home/.vim
home/.irbrc
home/.railsrc
home/.screenrc

# agent config (upstream PR #16 made .agents the source of truth; ~/.claude and
# ~/.gemini now reach it through shim symlinks). Rules stay curated here —
# macos-interactions.md and skill-authoring.md are intentionally excluded — and
# the .claude/rules shim below then resolves to exactly this set.
home/.agents/rules/language.md
home/.agents/rules/workflow.md
home/.agents/rules/markdown.md
home/.agents/rules/improvement.md
home/.agents/rules/prudence.md

# skills are taken wholesale; their per-skill links into the ext/ submodule
# escape the vendored tree, so 1b materializes them (agent stays self-contained).
home/.agents/skills

# claude (CLAUDE.md comes from the overlay). rules/ and skills/ are upstream
# shims into .agents/ — both resolve inside home/ now that .agents is vendored,
# so 1b keeps them verbatim rather than deref'ing upstream's wider set.
home/.claude/rules
home/.claude/settings.json
home/.claude/sync-plugins.sh
home/.claude/skills
home/.claude/agents
home/.claude/commands
home/.claude/hooks
home/.claude/output-styles
home/.claude/plugins

# antigravity CLI: just the relative link into .agents, so ~/.gemini stays a real
# directory holding its own runtime state. It resolves inside home/, so the
# agent's Antigravity skills track OUR vendored set — build.sh keeps it verbatim
# rather than materializing upstream's. Antigravity's own settings.json/
# keybindings.json are the human's, and stay out. (Upstream's antigravity-cli/
# rules link went away with PR #16 — Antigravity never read it.)
home/.gemini/antigravity-cli/skills
